# Copy to .env and adjust for your local setup

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=api_analytics
POSTGRES_USER=api_analytics
POSTGRES_PASSWORD=change_me_locally

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:29092

# Topics (defaults — override only if you must)
KAFKA_TOPIC_API_LOGS=api-logs
KAFKA_TOPIC_API_LOGS_DLQ=api-logs-dlq
KAFKA_TOPIC_METRICS=metrics
KAFKA_TOPIC_ALERTS=alerts
KAFKA_TOPIC_PREDICTIONS=predictions
KAFKA_TOPIC_SERVICE_HEALTH=service-health

# ─── Auth / JWT ─────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_ISSUER=innovations-api
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ─── Service ports (host-side) ──────────────────────────────
PORT_GATEWAY=8080
PORT_AUTH=8081
PORT_REGISTRY=8082
PORT_METRICS_COLLECTOR=8083
PORT_ANALYTICS=8084
PORT_DASHBOARD=8085
PORT_ML=8000

# ─── ML service ─────────────────────────────────────────────
ML_MODEL_DIR=/app/models
ML_ANALYTICS_BASE_URL=http://analytics-service:8084
ML_TRAINING_SCHEDULE_CRON=0 3 * * *

# ─── Dashboard resilience ───────────────────────────────────
DASHBOARD_ML_TIMEOUT_MS=2000
DASHBOARD_ML_CIRCUIT_FAILURE_THRESHOLD=5
